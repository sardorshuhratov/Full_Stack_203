# Copy to .env and set values
PORT=3000
# Optional webhook secret used to validate incoming webhook requests
WEBHOOK_SECRET=change_me

# SMTP settings (optional) - if set, order confirmations will be emailed
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false # true for port 465
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
MAIL_FROM="Tech House <no-reply@example.com>"
